{
  "name": "premier-league",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "An unofficial, timezone-aware Premier League fixture viewer",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "fetch:fixtures": "node scripts/fetch-fixtures.mjs",
    "fetch:history": "node scripts/fetch-history.mjs",
    "fetch:stats": "node scripts/fetch-stats.mjs",
    "fetch:all": "npm run fetch:fixtures && npm run fetch:stats && npm run fetch:history"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.9",
    "jsdom": "^25.0.1",
    "vite": "^5.4.11",
    "vitest": "^2.1.9"
  }
}
